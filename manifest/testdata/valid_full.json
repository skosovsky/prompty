{
  "id": "support_agent",
  "version": "1.2",
  "description": "Customer support agent",
  "model_config": {"temperature": 0.7, "max_tokens": 2048},
  "input_schema": {
    "name": "support_agent_input",
    "schema": {
      "type": "object",
      "properties": {
        "user_query": {"type": "string"},
        "bot_name": {"type": "string", "default": "SupportBot"}
      },
      "required": ["user_query"]
    }
  },
  "tools": [{"name": "get_order_status", "description": "Get order status", "parameters": {"type": "object", "properties": {"order_id": {"type": "string"}}}}],
  "messages": [
    {"role": "system", "content": [{"type": "text", "text": "You are {{ .bot_name }}. {{ render_tools_as_xml .Tools }}"}]},
    {"role": "user", "content": [{"type": "text", "text": "{{ .user_query }}"}], "optional": true}
  ]
}
